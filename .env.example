# ─── Database (PostgreSQL) ───────────────────────────────
# Local: postgresql://user:pass@localhost:5432/lumen
# Prod (Vercel/Railway/Neon/Supabase): use the pooled connection string
DATABASE_URL="postgresql://user:password@localhost:5432/lumen?schema=public"
# Direct (non-pooled) URL for migrations, if your host requires it
DIRECT_URL="postgresql://user:password@localhost:5432/lumen?schema=public"

# ─── Site ────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ─── Booking backend selection ───────────────────────────
# "self" = self-hosted Availability calendar (default)
# "calcom" = Cal.com embed + webhook
BOOKING_PROVIDER="self"

# ─── Email (Resend) ──────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxx"
# Verified sender + the photographer's inbox that receives new bookings
EMAIL_FROM="Krasnovska PH <hello@krasnovska.ph>"
EMAIL_TO_OWNER="you@krasnovska.ph"

# ─── Telegram (optional duplicate notification) ──────────
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# ─── Cal.com (only if BOOKING_PROVIDER=calcom) ───────────
NEXT_PUBLIC_CALCOM_LINK="krasnovska/session"
CALCOM_WEBHOOK_SECRET="whsec_xxxxxxxx"
